  "designGuidance": {
    "colorUsage": {
      "primary": "Use for main CTAs, headings, and brand elements",
      "secondary": "Use for secondary actions and highlights",
      "neutral": "Use for body text, borders, and backgrounds",
      "gradients": "Combine primary and secondary blues for hero sections and CTAs"
    },
    "typography": {
      "headings": "Use bold weights (600-700) for all headings",
      "body": "Use regular weight (400) for body text",
      "spacing": "Maintain consistent line-height ratios for readability"
    },
    "spacing": {
      "sections": "Use 4xl-6xl spacing between major sections",
      "elements": "Use md-xl spacing between related elements",
      "components": "Use sm-md internal padding for cards and containers"
    },
    "imagery": {
      "hero": "Use high-quality industrial/technology imagery",
      "products": "Showcase products with clean backgrounds and proper lighting",
      "team": "Professional headshots with consistent backgrounds",
      "blog": "Relevant stock imagery matching article topics"
    }
  },
  "exportGuidance": {
    "images": {
      "format": "Export as WebP/AVIF for optimal performance",
      "sizes": "Provide 1x, 2x, and 3x versions for responsive images",
      "optimization": "Compress images while maintaining quality (80-85% quality)"
    },
    "icons": {
      "format": "Export as SVG with viewBox attribute",
      "style": "Use mono-color fills with tokenized color references",
      "size": "Create at 24x24 base size for consistent scaling"
    },
    "tokens": {
      "handoff": "Provide token JSON to developers",
      "css-variables": "Map to CSS custom properties (e.g., --color-primary: #1E3A8A)",
      "naming": "Use consistent BEM-style naming conventions"
    },
    "animations": {
      "duration": "Use 200-400ms for micro-interactions",
      "easing": "Apply ease-out cubic for natural motion",
      "triggers": "Document hover, focus, and scroll-triggered animations"
    },
    "responsive": {
      "breakpoints": {
        "mobile": 320,
        "tablet": 768,
        "desktop": 1024,
        "wide": 1440
      },
      "strategy": "Mobile-first approach with progressive enhancement"
    }
  },
